# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== PostgreSQL ma'lumotlar bazasi =====
# Variant A — Supabase (yoki boshqa bulut): faqat ulanish satrini qo'ying.
# Berilsa, pastdagi DB_* qiymatlari o'rniga shu ishlatiladi (SSL avtomatik yoqiladi).
# DATABASE_URL=postgresql://postgres:[PAROL]@db.[REF].supabase.co:5432/postgres

# Variant B — lokal PostgreSQL (DATABASE_URL bo'sh qolsa ishlatiladi)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=toyxona_db
# Lokal bazaga SSL kerak bo'lsa (odatda kerak emas): DB_SSL=true

# ===== JWT autentifikatsiya =====
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# ===== Email — PRODUCTION (Brevo HTTP API, tavsiya etiladi) =====
# Render kabi hostlar SMTP'ni bloklaydi -> Brevo HTTP orqali ishlaydi.
# BREVO_API_KEY bo'lsa, pastdagi SMTP o'rniga shu ishlatiladi.
# BREVO_API_KEY=xkeysib-xxxxxxxx

# ===== Email — LOKAL (Nodemailer SMTP / Gmail) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password
# EMAIL_FROM — Brevo'da TASDIQLANGAN jo'natuvchi email bo'lishi kerak
EMAIL_FROM="To'yxona Bron Tizimi <your_email@gmail.com>"

# ===== Frontend manzili (CORS uchun) =====
CLIENT_URL=http://localhost:5173
